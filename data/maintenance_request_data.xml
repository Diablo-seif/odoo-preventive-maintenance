<odoo>
    <data>

        <record id="ir_cron_maintenance_request" model="ir.cron">
            <field name="name">Maintenance Request: Run Plan</field>
            <field name="model_id" ref="maintenance.model_maintenance_request"/>
            <field name="state">code</field>
            <field name="code">model.maintenance_request_plans()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>

</odoo>

